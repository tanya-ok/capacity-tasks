{
	"$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"linter": {
		"enabled": true,
		"rules": { "recommended": true }
	},
	"javascript": {
		"formatter": { "quoteStyle": "single" }
	},
	"files": {
		"includes": ["src/**", "esbuild.config.mjs"]
	}
}
