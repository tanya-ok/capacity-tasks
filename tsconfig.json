{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": ["DOM", "ES2022"],
		"strict": true,
		"noImplicitAny": true,
		"noUnusedLocals": true,
		"importHelpers": true,
		"isolatedModules": true,
		"skipLibCheck": true,
		"noEmit": true
	},
	"include": ["src/**/*.ts"]
}
